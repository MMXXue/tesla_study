# =================================================================
# TS-79 Diagnostic Expert - 环境配置模板 (.env.example)
# 使用说明：复制此文件并重命名为 .env，然后填写对应的真实数值
# =================================================================

# --- 基础设置 ---
PROJECT_NAME="TS-79 Diagnostic Expert"
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- 数据库配置 (PostgreSQL) ---
# 注意：在生产环境中，建议使用非 root 用户
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ts79_db_name

# 数据库连接 URL 模板 (供代码内部拼接参考)
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- 缓存配置 (Redis) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_if_any

# --- AI 模型配置 (DeepSeek) ---
# 请从 https://platform.deepseek.com/ 申请 API KEY
DEEP_SEEK_API_KEY=sk-your-unique-api-key-here
DEEP_SEEK_BASE_URL=https://api.deepseek.com/v1

# --- 其他配置 ---
# 如果有特定的环境标识（dev/test/prod）
ENV_MODE=dev